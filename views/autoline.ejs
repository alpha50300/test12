<link rel="stylesheet" href="/css/rules.css">

<div class="page-header"
    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px;">
    <div>
        <h2 style="font-size: 2rem; margin-bottom: 10px;"><i class="fas fa-grip-lines"></i>
            <%= __('auto_line_system') %>
        </h2>
        <p style="color: var(--text-muted);">Automatically post a line image after every message in specific channels.
        </p>
    </div>
    <div style="display: flex; gap: 10px;">
        <label class="switch" style="display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" id="autoLineToggle" <%=settings.autoLineEnabled ? 'checked' : '' %>
            onchange="toggleAutoLine()">
            <span class="slider round"></span>
            <span style="color: var(--text-muted);">Enable System</span>
        </label>
        <button onclick="saveAutoLineSettings()" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Settings
        </button>
    </div>
</div>

<div class="glass" style="padding: 25px;">
    <div
        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 10px;">
        <h3>Configured Channels</h3>
        <button onclick="addChannel()" class="btn btn-secondary"><i class="fas fa-plus"></i> Add Channel</button>
    </div>

    <div id="linesContainer">
        <!-- Lines will be injected here -->
    </div>
</div>

<script>
    let lines = JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify(settings.autoLines || [])) %>'));
    const availableChannels = JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify(channels)) %>'));

    function renderLines() {
        const container = document.getElementById('linesContainer');
        container.innerHTML = '';

        if (lines.length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:20px; color:var(--text-muted);">No channels configured.</div>';
            return;
        }

        lines.forEach((line, index) => {
            const el = document.createElement('div');
            el.className = 'glass';
            el.style = 'background: rgba(0,0,0,0.2); padding: 15px; margin-bottom: 15px; display:flex; gap:15px; align-items:start;';

            let channelOptions = availableChannels.map(c => `<option value="${c.id}" ${line.channelId === c.id ? 'selected' : ''}>#${c.name}</option>`).join('');

            el.innerHTML = `
                <div style="flex:1;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                        <select class="custom-select" onchange="updateLine(${index}, 'channelId', this.value)">
                            <option value="">Select Channel...</option>
                            ${channelOptions}
                        </select>
                        <button onclick="removeLine(${index})" class="btn btn-delete" style="padding:5px 10px;"><i class="fas fa-trash"></i></button>
                    </div>
                    
                    <div style="margin-bottom:10px;">
                        <label style="font-size:0.8rem; color:var(--text-muted);">Line Image URL</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="text" class="form-input" value="${line.imageUrl || ''}" placeholder="https://..." onchange="updateLine(${index}, 'imageUrl', this.value)">
                            <img src="${line.imageUrl || ''}" style="height: 40px; border-radius: 4px; display: ${line.imageUrl ? 'block' : 'none'}" onerror="this.style.display='none'">
                        </div>
                    </div>
                </div>
            `;
            container.appendChild(el);
        });
    }

    function addChannel() {
        lines.push({ channelId: '', imageUrl: '' });
        renderLines();
    }

    function removeLine(index) {
        lines.splice(index, 1);
        renderLines();
    }

    function updateLine(index, field, value) {
        lines[index][field] = value;
        renderLines(); // Re-render to show image preview if URL changes
    }

    async function saveAutoLineSettings() {
        const settings = {
            autoLineEnabled: document.getElementById('autoLineToggle').checked,
            autoLines: lines
        };

        try {
            const res = await fetch('/api/autoline/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(settings)
            });
            const data = await res.json();
            if (data.success) alert('Settings saved!');
            else alert('Error: ' + data.message);
        } catch (err) {
            console.error(err);
            alert('Failed to save settings.');
        }
    }

    renderLines();
</script>